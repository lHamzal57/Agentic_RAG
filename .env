# RAG
# Default RAG
RAG_ENABLED=true
RAG_USE_OLLAMA=true
RAG_USE_CHROMA=true

# Retrieval / reranking
RAG_RERANK_ENABLED=true
RAG_RETRIEVAL_CANDIDATE_MULTIPLIER=3
RAG_RETRIEVAL_CANDIDATE_MAX=30
RAG_RERANK_MIN_CHUNK_CHARS=80

# Existing retrieval neighbor expansion (keep if already added)
RAG_RETRIEVAL_EXPAND_NEIGHBORS=true
RAG_RETRIEVAL_NEIGHBOR_RADIUS=1
RAG_PROMPT_SORT_CHUNKS_BY_INDEX=true

# Workflow-specific Top-K overrides
RAG_TOP_K_GENERAL_QUESTION=5
RAG_TOP_K_SYSTEM_ARCHITECTURE=8
RAG_TOP_K_TEST_CASES=6
RAG_TOP_K_TEST_PLAN=10
RAG_TOP_K_TEST_REVIEW=7

# Chunking tuning
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=150
RAG_SEMANTIC_WINDOW_MAX_CHARS=3000

# TestCases pre-step (derive use cases from doc using LLM)
RAG_TESTCASES_AUTOGEN_USECASES=true
RAG_USECASES_TOP_K=8
RAG_USECASES_CACHE_ENABLED=true

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GENERATE_PATH=/api/generate
OLLAMA_MODEL=tinyllama:latest
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_CTX=131072
OLLAMA_NUM_PREDICT=512
OLLAMA_TOP_K=40
OLLAMA_TOP_P=0.9
